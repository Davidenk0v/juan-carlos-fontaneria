---
// ⚠️  ACTUALIZA SITE_URL con tu dominio real antes de publicar
const SITE_URL = 'https://tudominio.es';

const DESCRIPTION = 'Fontanero autorizado en Tenerife con más de 20 años de experiencia. Reparaciones urgentes 24h, instalaciones de agua, calefacción, termos y mantenimiento preventivo. Licencia N° 05-B-D90. Presupuesto gratuito.';

const TITLE = 'L&M Fontanería — Fontanero Autorizado en Tenerife | Urgencias 24h';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Plumber", "LocalBusiness"],
      "@id": `${SITE_URL}/#business`,
      "name": "Juan Carlos Luis",
      "alternateName": "L&M Fontanería",
      "description": DESCRIPTION,
      "url": SITE_URL,
      "telephone": "+34643368225",
      "email": "luismedinagua@gmail.com",
      "priceRange": "$$",
      "currenciesAccepted": "EUR",
      "paymentAccepted": "Efectivo, Transferencia bancaria",
      "identifier": {
        "@type": "PropertyValue",
        "name": "Licencia de fontanero",
        "value": "05-B-D90"
      },
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "Tenerife",
        "containedInPlace": {
          "@type": "Country",
          "name": "España"
        }
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "08:00",
          "closes": "20:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "09:00",
          "closes": "15:00"
        }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de fontanería en Tenerife",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Reparaciones de urgencia 24h",
              "description": "Servicio urgente disponible 24 horas para fugas de agua, atascos, roturas de tuberías y cualquier avería de fontanería."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Instalaciones de agua",
              "description": "Instalación completa de tuberías, grifería, sanitarios y sistemas de agua con garantía en materiales y mano de obra."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Calefacción y termos",
              "description": "Instalación y mantenimiento de calderas de gas, termos eléctricos, radiadores y sistemas de calefacción."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Mantenimiento preventivo",
              "description": "Revisiones periódicas de instalaciones de fontanería para prevenir averías y optimizar el rendimiento."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Grupos de bombeo",
              "description": "Instalación y reparación de grupos de presión y bombas de agua."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Fontanería para piscinas",
              "description": "Instalación y mantenimiento de sistemas hidráulicos para piscinas."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Sistemas sanitarios",
              "description": "Instalación y reparación de sistemas sanitarios: inodoros, duchas, bañeras y lavabos."
            }
          }
        ]
      },
      "availableLanguage": {
        "@type": "Language",
        "name": "Spanish"
      },
      "knowsAbout": [
        "Fontanería", "Reparaciones de agua", "Instalaciones sanitarias",
        "Calefacción", "Termos eléctricos", "Calderas de gas",
        "Grupos de bombeo", "Mantenimiento preventivo", "Urgencias 24h"
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      "url": SITE_URL,
      "name": "Juan Carlos Luis — Fontanero Autorizado Tenerife",
      "description": DESCRIPTION,
      "inLanguage": "es",
      "publisher": { "@id": `${SITE_URL}/#business` }
    }
  ]
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <meta name="keywords" content="fontanero tenerife, fontanero urgencias 24 horas, reparaciones fontanería, instalaciones agua tenerife, calefacción tenerife, termos eléctricos, fontanero autorizado canarias, grupos bombeo, fontanero económico, fugas agua, atascos, mantenimiento fontanería, fontanero licenciado" />
    <meta name="author" content="Juan Carlos Luis" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={SITE_URL} />

    <!-- Geolocalización -->
    <meta name="geo.region" content="ES-TF" />
    <meta name="geo.placename" content="Tenerife, Islas Canarias, España" />
    <meta name="language" content="es" />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn…) -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Juan Carlos Luis Fontanero" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content={SITE_URL} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/logo.webp" />

    <!-- Fuente -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="font-inter antialiased">
    <slot />

    <!-- Botón flotante WhatsApp -->
    <a
      href="https://wa.me/34643368225"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-green-500 hover:bg-green-400 text-white rounded-full shadow-lg shadow-green-500/30 flex items-center justify-center transition-all duration-300 hover:scale-110"
    >
      <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
      </svg>
    </a>
  </body>
</html>
