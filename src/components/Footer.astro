---
import { Image } from "astro:assets";
import logo from "../assets/logo_blanco.webp";
---

<footer class="bg-void text-chalk">

  <!-- Línea de cobre superior -->
  <div class="h-px bg-gradient-to-r from-transparent via-copper/60 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <div class="grid md:grid-cols-4 gap-10">

      <!-- Columna marca -->
      <div class="md:col-span-2">
        <a href="#inicio" class="flex items-center gap-3 mb-5">
          <Image
            src={logo}
            alt="Logo L&M Fontanería"
            width={44}
            height={44}
            class="w-11 h-11 object-contain opacity-80"
          />
          <div>
            <p class="font-bold text-chalk leading-none">L&M Fontanería</p>
            <p class="text-xs text-chalk-mute mt-0.5 font-medium tracking-wide">Fontanero Autorizado N° 05-B-D90</p>
          </div>
        </a>
        <p class="text-chalk-mute text-sm leading-relaxed mb-4 max-w-sm">
          Tu fontanero de confianza en Tenerife. Más de 20 años garantizando reparaciones, instalaciones y mantenimiento de fontanería con el nivel de calidad que mereces.
        </p>
        <address class="not-italic text-chalk-mute text-xs mb-7 flex items-center gap-2">
          <svg class="w-3.5 h-3.5 text-copper shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Tenerife, Islas Canarias, España
        </address>
        <div class="flex items-center gap-3">
          <a
            href="https://wa.me/34643368225"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-green-600/20 hover:bg-green-600/40 border border-green-600/20 rounded-xl flex items-center justify-center transition-all duration-200"
            aria-label="WhatsApp"
          >
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
            </svg>
          </a>
          <a
            href="tel:643368225"
            class="w-10 h-10 bg-copper/15 hover:bg-copper/30 border border-copper/20 rounded-xl flex items-center justify-center transition-all duration-200"
            aria-label="Teléfono"
          >
            <svg class="w-5 h-5 text-copper" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
            </svg>
          </a>
          <a
            href="mailto:luismedinagua@gmail.com"
            class="w-10 h-10 bg-chalk/5 hover:bg-chalk/10 border border-chalk/10 rounded-xl flex items-center justify-center transition-all duration-200"
            aria-label="Email"
          >
            <svg class="w-5 h-5 text-chalk-dim" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navegación -->
      <div>
        <h4 class="text-xs font-bold text-chalk-dim uppercase tracking-widest mb-5">Navegación</h4>
        <ul class="space-y-3">
          <li><a href="#inicio"    class="text-chalk-mute hover:text-copper text-sm transition-colors duration-200">Inicio</a></li>
          <li><a href="#servicios" class="text-chalk-mute hover:text-copper text-sm transition-colors duration-200">Servicios</a></li>
          <li><a href="#trabajos"  class="text-chalk-mute hover:text-copper text-sm transition-colors duration-200">Trabajos</a></li>
          <li><a href="#contacto"  class="text-chalk-mute hover:text-copper text-sm transition-colors duration-200">Contacto</a></li>
        </ul>
      </div>

      <!-- Servicios -->
      <div>
        <h4 class="text-xs font-bold text-chalk-dim uppercase tracking-widest mb-5">Servicios</h4>
        <ul class="space-y-3">
          <li><span class="text-chalk-mute text-sm">Mantenimiento e instalaciones</span></li>
          <li><span class="text-chalk-mute text-sm">Grupos de bombeo</span></li>
          <li><span class="text-chalk-mute text-sm">Piscinas</span></li>
          <li><span class="text-chalk-mute text-sm">Sistemas sanitarios</span></li>
          <li><span class="text-chalk-mute text-sm">Calentadores</span></li>
          <li><span class="text-chalk-mute text-sm">Electricidad y saneamiento</span></li>
        </ul>
      </div>

    </div>

    <!-- Barra inferior -->
    <div class="border-t border-rim mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-chalk-mute text-sm">
        © 2026 L&M Fontanería. Todos los derechos reservados.
      </p>
      <p class="text-chalk-mute text-sm">
        Diseñado por <a href="https://www.linkedin.com/in/luis-david-%C3%A1lvarez-perdig%C3%B3n-67135b271/" class="text-chalk-dim hover:text-copper transition-colors duration-200 underline underline-offset-2">Luis David Álvarez</a>
      </p>
    </div>

  </div>
</footer>
