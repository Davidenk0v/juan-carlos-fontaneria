---
const bgMap = {
  red:    "bg-red-50",
  sky:   "bg-sky-50",
  emerald:  "bg-emerald-50",
  orange: "bg-orange-50",
} as const;

type Background = keyof typeof bgMap;

interface Props {
  title: string;
  description: string;
  background: Background;
  note: string;
}

const { title, description, note, background } = Astro.props
const bgClass = bgMap[background];
const bgClassNote = bgMap[background].replace("50", "400");
const textClassNote = bgClassNote.replace("bg-", "text-");
const hopperClass = `group-hover:${bgClass.replace("50", "100")}`;
---

      <div class="group bg-white border border-slate-100 rounded-2xl p-7 shadow-sm hover:shadow-xl hover:-translate-y-1.5 hover:border-red-100 transition-all duration-300">
        <div class={`w-12 h-12 ${bgClass} ${hopperClass} rounded-xl flex items-center justify-center mb-5 transition-colors duration-300`}>
            <slot name="icon" />
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-2">{title}</h3>
        <p class="text-slate-500 text-sm leading-relaxed">
          {description}
        </p>
        <div class={`mt-5 flex items-center gap-1.5 ${textClassNote} text-sm font-semibold`}>
          <span class={`w-1.5 h-1.5 ${bgClassNote} rounded-full animate-pulse`}></span>
            <slot name="check" />{note}
        </div>
      </div>