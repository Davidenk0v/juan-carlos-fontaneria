---
const iconBgMap = {
  red:     "bg-red-500/10     border-red-500/20     text-red-400",
  sky:     "bg-sky-500/10     border-sky-500/20     text-sky-400",
  emerald: "bg-emerald-500/10 border-emerald-500/20 text-emerald-400",
  orange:  "bg-orange-500/10  border-orange-500/20  text-orange-400",
} as const;

const noteColorMap = {
  red:     "text-red-400",
  sky:     "text-sky-400",
  emerald: "text-emerald-400",
  orange:  "text-orange-400",
} as const;

type Background = keyof typeof iconBgMap;

interface Props {
  title: string;
  description: string;
  background: Background;
  note: string;
}

const { title, description, note, background } = Astro.props;
const iconBg    = iconBgMap[background];
const noteColor = noteColorMap[background];
---

<div class="group bg-raised border border-rim rounded-2xl p-7 hover:bg-high hover:border-border hover:-translate-y-1 transition-all duration-300 shadow-sm">
  <div class={`w-12 h-12 ${iconBg} border rounded-xl flex items-center justify-center mb-5 transition-colors duration-300`}>
    <slot name="icon" />
  </div>
  <h3 class="text-base font-bold text-chalk mb-2">{title}</h3>
  <p class="text-chalk-dim text-sm leading-relaxed">
    {description}
  </p>
  <div class={`mt-5 flex items-center gap-1.5 ${noteColor} text-xs font-bold tracking-wide uppercase`}>
    <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
    {note}
  </div>
</div>
