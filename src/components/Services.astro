---
---

<section id="servicios" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">
        Nuestros Servicios
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Ofrecemos soluciones completas de fontanería con la garantía de un profesional autorizado
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 border border-gray-100">
        <div class="w-16 h-16 bg-gradient-to-br from-red-500 to-red-600 rounded-2xl flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Reparaciones de Urgencia</h3>
        <p class="text-gray-600 leading-relaxed">
          Servicio 24/7 para averías y emergencias. Atención inmediata para fugas, atascos y problemas urgentes.
        </p>
        <div class="mt-6 flex items-center text-red-600 font-semibold">
          <span>Disponible 24h</span>
          <svg class="w-4 h-4 ml-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 border border-gray-100">
        <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-cyan-400 rounded-2xl flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3zm5 15h-2v-6H9v6H7v-6.59l5-4.5 5 4.5V18z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Instalaciones de Agua</h3>
        <p class="text-gray-600 leading-relaxed">
          Instalación completa de sistemas de agua, tuberías, grifería y sanitarios con materiales de calidad.
        </p>
        <div class="mt-6 flex items-center text-blue-600 font-semibold">
          <span>Garantía incluida</span>
          <svg class="w-4 h-4 ml-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 border border-gray-100">
        <div class="w-16 h-16 bg-gradient-to-br from-orange-500 to-red-500 rounded-2xl flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.5 2C13.3 2 14 2.7 14 3.5v2c0 .8-.7 1.5-1.5 1.5S11 6.3 11 5.5v-2c0-.8.7-1.5 1.5-1.5zM21 11h-2c-.8 0-1.5.7-1.5 1.5s.7 1.5 1.5 1.5h2c.8 0 1.5-.7 1.5-1.5S21.8 11 21 11zM6.5 11H5c-.8 0-1.5.7-1.5 1.5S4.2 14 5 14h1.5c.8 0 1.5-.7 1.5-1.5S7.3 11 6.5 11zM7.34 6.05L6.05 7.34c-.39.39-.39 1.02 0 1.41.39.39 1.02.39 1.41 0l1.29-1.29c.39-.39.39-1.02 0-1.41-.39-.39-1.02-.39-1.41 0zM17.66 6.05c-.39-.39-1.02-.39-1.41 0-.39.39-.39 1.02 0 1.41l1.29 1.29c.39.39 1.02.39 1.41 0 .39-.39.39-1.02 0-1.41L17.66 6.05zM12 9c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Calefacción y Termos</h3>
        <p class="text-gray-600 leading-relaxed">
          Instalación y mantenimiento de sistemas de calefacción, termos eléctricos y calderas de gas.
        </p>
        <div class="mt-6 flex items-center text-orange-600 font-semibold">
          <span>Eficiencia garantizada</span>
          <svg class="w-4 h-4 ml-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.5 2C13.3 2 14 2.7 14 3.5v2c0 .8-.7 1.5-1.5 1.5S11 6.3 11 5.5v-2c0-.8.7-1.5 1.5-1.5z"/>
          </svg>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 border border-gray-100">
        <div class="w-16 h-16 bg-gradient-to-br from-green-500 to-emerald-500 rounded-2xl flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Mantenimiento Preventivo</h3>
        <p class="text-gray-600 leading-relaxed">
          Revisiones periódicas y mantenimiento para evitar averías futuras y optimizar el rendimiento.
        </p>
        <div class="mt-6 flex items-center text-green-600 font-semibold">
          <span>Ahorro a largo plazo</span>
          <svg class="w-4 h-4 ml-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7.41 8.58L12 13.17l4.59-4.59L18 10l-6 6-6-6 1.41-1.42z"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="mt-16 text-center">
      <div class="bg-gradient-to-r from-blue-800 to-cyan-400 rounded-2xl p-8 text-white">
        <h3 class="text-2xl font-bold mb-4">¿Necesitas una consulta personalizada?</h3>
        <p class="text-blue-100 mb-6 text-lg">
          Contáctanos para recibir un presupuesto gratuito y sin compromiso
        </p>
        <a 
          href="#contacto" 
          class="inline-flex items-center px-8 py-4 bg-white text-blue-800 font-semibold rounded-2xl hover:bg-gray-100 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
          </svg>
          Llamar Ahora
        </a>
      </div>
    </div>
  </div>
</section>