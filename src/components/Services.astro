---
---

<section id="servicios" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Cabecera -->
    <div class="text-center mb-16">
      <p class="text-sky-500 font-semibold text-sm tracking-widest uppercase mb-3">Servicios</p>
      <h2 class="text-4xl font-bold text-slate-900 mb-4">
        Todo lo que necesitas
      </h2>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto">
        Soluciones completas de fontanería con la garantía de un profesional autorizado
      </p>
    </div>

    <!-- Tarjetas de servicios -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- Reparaciones de Urgencia -->
      <div class="group bg-white border border-slate-100 rounded-2xl p-7 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
        <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-2">Reparaciones de Urgencia</h3>
        <p class="text-slate-500 text-sm leading-relaxed">
          Servicio 24/7 para averías y emergencias. Atención inmediata para fugas, atascos y problemas urgentes.
        </p>
        <div class="mt-5 flex items-center gap-1.5 text-red-500 text-sm font-semibold">
          <span class="w-1.5 h-1.5 bg-red-400 rounded-full animate-pulse"></span>
          Disponible 24h
        </div>
      </div>

      <!-- Instalaciones de Agua -->
      <div class="group bg-white border border-slate-100 rounded-2xl p-7 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
        <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-2">Instalaciones de Agua</h3>
        <p class="text-slate-500 text-sm leading-relaxed">
          Instalación completa de sistemas de agua, tuberías, grifería y sanitarios con materiales de calidad.
        </p>
        <div class="mt-5 flex items-center gap-1.5 text-sky-500 text-sm font-semibold">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Garantía incluida
        </div>
      </div>

      <!-- Calefacción y Termos -->
      <div class="group bg-white border border-slate-100 rounded-2xl p-7 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
        <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-2">Calefacción y Termos</h3>
        <p class="text-slate-500 text-sm leading-relaxed">
          Instalación y mantenimiento de sistemas de calefacción, termos eléctricos y calderas de gas.
        </p>
        <div class="mt-5 flex items-center gap-1.5 text-orange-500 text-sm font-semibold">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Eficiencia garantizada
        </div>
      </div>

      <!-- Mantenimiento Preventivo -->
      <div class="group bg-white border border-slate-100 rounded-2xl p-7 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
        <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-2">Mantenimiento Preventivo</h3>
        <p class="text-slate-500 text-sm leading-relaxed">
          Revisiones periódicas y mantenimiento para evitar averías futuras y optimizar el rendimiento.
        </p>
        <div class="mt-5 flex items-center gap-1.5 text-emerald-500 text-sm font-semibold">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Ahorro a largo plazo
        </div>
      </div>

    </div>

    <!-- Separador con razones para elegirnos -->
    <div class="mt-20 pt-16 border-t border-slate-100">
      <div class="text-center mb-12">
        <p class="text-sky-500 font-semibold text-sm tracking-widest uppercase mb-3">¿Por qué elegirnos?</p>
        <h3 class="text-3xl font-bold text-slate-900">Más de 20 años de experiencia</h3>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">

        <div class="text-center">
          <div class="w-14 h-14 bg-sky-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
          </div>
          <h4 class="font-bold text-slate-900 mb-2">Fontanero Autorizado</h4>
          <p class="text-slate-500 text-sm leading-relaxed">Licencia oficial N° 05-B-D90. Trabajo profesional y certificado.</p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-red-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-bold text-slate-900 mb-2">Urgencias 24/7</h4>
          <p class="text-slate-500 text-sm leading-relaxed">Disponible todos los días, a cualquier hora, incluso festivos.</p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-bold text-slate-900 mb-2">Presupuesto Gratuito</h4>
          <p class="text-slate-500 text-sm leading-relaxed">Sin compromiso y sin coste. Valoramos tu problema antes de cobrar.</p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-orange-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h4 class="font-bold text-slate-900 mb-2">Garantía Total</h4>
          <p class="text-slate-500 text-sm leading-relaxed">Garantía en materiales y mano de obra en todos los trabajos realizados.</p>
        </div>

      </div>
    </div>

  </div>
</section>
