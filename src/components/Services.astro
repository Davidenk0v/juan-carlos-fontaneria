---
import ServiceCard from "./ServiceCard.astro";
---

<section id="servicios" class="py-28 bg-surface relative overflow-hidden">

  <!-- Luz de acento sutil -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] rounded-full opacity-[0.06] pointer-events-none"
    style="background: radial-gradient(ellipse at center, #cf7840 0%, transparent 70%); filter: blur(60px);"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Cabecera -->
    <div class="text-center mb-16">
      <p class="text-copper font-bold text-xs tracking-widest uppercase mb-4">Servicios</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-chalk mb-5 leading-tight">
        Servicios de fontanería en Tenerife
      </h2>
      <p class="text-chalk-dim text-lg max-w-2xl mx-auto leading-relaxed">
        Soluciones completas de fontanería con la garantía de un profesional autorizado
      </p>
    </div>

    <!-- Tarjetas de servicios -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">

      <ServiceCard title="Reparaciones de Urgencia" description="Servicio 24/7 para averías y emergencias. Atención inmediata para fugas, atascos y problemas urgentes." background="red" note="Disponible 24h">
        <svg slot="icon" class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </ServiceCard>

      <ServiceCard title="Instalaciones de Agua" description="Instalación completa de sistemas de agua, tuberías, grifería y sanitarios con materiales de calidad." background="sky" note="Garantía incluida">
        <svg slot="icon" class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
        </svg>
      </ServiceCard>

      <ServiceCard title="Calefacción y Termos" description="Instalación y mantenimiento de sistemas de calefacción, termos eléctricos y calderas de gas." background="orange" note="Eficiencia garantizada">
        <svg slot="icon" class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>
        </svg>
      </ServiceCard>

      <ServiceCard title="Mantenimiento Preventivo" description="Revisiones periódicas para evitar averías, prolongar la vida útil y garantizar el correcto funcionamiento." background="emerald" note="Ahorro a largo plazo">
        <svg slot="icon" class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </ServiceCard>

    </div>

    <!-- Por qué elegirnos -->
    <div class="mt-20">
      <!-- Línea divisora con título centrado -->
      <div class="flex items-center gap-6 mb-14">
        <div class="h-px bg-rim flex-1"></div>
        <div class="text-center shrink-0">
          <p class="text-copper font-bold text-xs tracking-widest uppercase mb-1">¿Por qué elegirnos?</p>
          <h3 class="font-display text-2xl md:text-3xl font-bold text-chalk">Más de 20 años de experiencia</h3>
        </div>
        <div class="h-px bg-rim flex-1"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <!-- Ítem 1 -->
        <div class="bg-raised border border-rim rounded-2xl p-6 text-center hover:border-border transition-all duration-300">
          <div class="w-12 h-12 bg-copper/10 border border-copper/20 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-copper" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
          </div>
          <h4 class="font-bold text-chalk mb-2 text-sm">Fontanero Autorizado</h4>
          <p class="text-chalk-mute text-xs leading-relaxed">Licencia oficial N° 05-B-D90. Trabajo profesional y certificado.</p>
        </div>

        <!-- Ítem 2 -->
        <div class="bg-raised border border-rim rounded-2xl p-6 text-center hover:border-border transition-all duration-300">
          <div class="w-12 h-12 bg-red-500/10 border border-red-500/20 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-bold text-chalk mb-2 text-sm">Urgencias 24/7</h4>
          <p class="text-chalk-mute text-xs leading-relaxed">Disponible todos los días, a cualquier hora, incluso festivos.</p>
        </div>

        <!-- Ítem 3 -->
        <div class="bg-raised border border-rim rounded-2xl p-6 text-center hover:border-border transition-all duration-300">
          <div class="w-12 h-12 bg-emerald-500/10 border border-emerald-500/20 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-bold text-chalk mb-2 text-sm">Presupuesto Gratuito</h4>
          <p class="text-chalk-mute text-xs leading-relaxed">Sin compromiso. Valoramos tu avería antes de cobrar nada.</p>
        </div>

        <!-- Ítem 4 -->
        <div class="bg-raised border border-rim rounded-2xl p-6 text-center hover:border-border transition-all duration-300">
          <div class="w-12 h-12 bg-copper/10 border border-copper/20 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-copper" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h4 class="font-bold text-chalk mb-2 text-sm">Garantía Total</h4>
          <p class="text-chalk-mute text-xs leading-relaxed">Garantía en materiales y mano de obra en todos los trabajos.</p>
        </div>

      </div>
    </div>

    <!-- Preguntas frecuentes -->
    <div class="mt-20" id="faq">

      <div class="flex items-center gap-6 mb-14">
        <div class="h-px bg-rim flex-1"></div>
        <div class="text-center shrink-0">
          <p class="text-copper font-bold text-xs tracking-widest uppercase mb-1">Preguntas frecuentes</p>
          <h2 class="font-display text-2xl md:text-3xl font-bold text-chalk">Lo que más nos preguntan</h2>
        </div>
        <div class="h-px bg-rim flex-1"></div>
      </div>

      <div class="max-w-3xl mx-auto space-y-3">

        <details class="bg-raised border border-rim rounded-2xl group open:border-copper/30 transition-all duration-200">
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-semibold text-chalk text-sm select-none">
            ¿Cuánto cuesta contratar un fontanero en Tenerife?
            <svg class="w-4 h-4 text-copper shrink-0 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </summary>
          <p class="px-6 pb-5 text-chalk-dim text-sm leading-relaxed">
            El coste depende del tipo de avería o instalación. Ofrecemos <strong class="text-chalk">presupuesto gratuito y sin compromiso</strong> antes de iniciar cualquier trabajo. Llama al 643 368 225 y te damos precio en el momento.
          </p>
        </details>

        <details class="bg-raised border border-rim rounded-2xl group open:border-copper/30 transition-all duration-200">
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-semibold text-chalk text-sm select-none">
            ¿Tenéis servicio de fontanero urgente 24 horas en Tenerife?
            <svg class="w-4 h-4 text-copper shrink-0 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </summary>
          <p class="px-6 pb-5 text-chalk-dim text-sm leading-relaxed">
            Sí. Atendemos <strong class="text-chalk">emergencias de fontanería las 24 horas del día, los 7 días de la semana</strong>, incluidos domingos y festivos, en toda la isla de Tenerife.
          </p>
        </details>

        <details class="bg-raised border border-rim rounded-2xl group open:border-copper/30 transition-all duration-200">
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-semibold text-chalk text-sm select-none">
            ¿Qué zonas de Tenerife cubrís?
            <svg class="w-4 h-4 text-copper shrink-0 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </summary>
          <p class="px-6 pb-5 text-chalk-dim text-sm leading-relaxed">
            Trabajamos en <strong class="text-chalk">toda la isla de Tenerife</strong>: Santa Cruz de Tenerife, San Cristóbal de La Laguna, Puerto de la Cruz, Adeje, Arona, Los Cristianos, Playa de las Américas, Güímar, Candelaria, La Orotava y más municipios.
          </p>
        </details>

        <details class="bg-raised border border-rim rounded-2xl group open:border-copper/30 transition-all duration-200">
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-semibold text-chalk text-sm select-none">
            ¿Estáis certificados como fontaneros autorizados?
            <svg class="w-4 h-4 text-copper shrink-0 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </summary>
          <p class="px-6 pb-5 text-chalk-dim text-sm leading-relaxed">
            Sí. Operamos con la <strong class="text-chalk">licencia oficial de fontanero N° 05-B-D90</strong>, expedida en Canarias. Todos los trabajos cumplen la normativa vigente y cuentan con garantía en materiales y mano de obra.
          </p>
        </details>

        <details class="bg-raised border border-rim rounded-2xl group open:border-copper/30 transition-all duration-200">
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-semibold text-chalk text-sm select-none">
            ¿Instaláis termos eléctricos y calderas de gas en Tenerife?
            <svg class="w-4 h-4 text-copper shrink-0 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </summary>
          <p class="px-6 pb-5 text-chalk-dim text-sm leading-relaxed">
            Sí. Instalamos y mantenemos <strong class="text-chalk">termos eléctricos, calderas de gas, radiadores</strong> y todo tipo de sistemas de calefacción y agua caliente sanitaria en Tenerife.
          </p>
        </details>

      </div>
    </div>

  </div>
</section>
