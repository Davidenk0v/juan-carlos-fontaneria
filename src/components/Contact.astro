<section id="contacto" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">
        Contáctanos
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Estamos aquí para ayudarte. Contáctanos por el medio que prefieras o solicita tu presupuesto gratuito
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <div class="space-y-8">
        <div class="grid sm:grid-cols-2 gap-6">
          <a 
            href="https://wa.me/34643368225" 
            target="_blank"
            class="bg-green-50 border border-green-200 rounded-2xl p-6 hover:bg-green-100 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl"
          >
            <div class="flex items-center space-x-4">
              <div class="w-12 h-12 bg-green-500 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900">WhatsApp</h3>
                <p class="text-green-600 font-semibold">643 368 225</p>
                <p class="text-sm text-gray-500">Respuesta inmediata</p>
              </div>
            </div>
          </a>

          <a 
            href="tel:643368225"
            class="bg-blue-50 border border-blue-200 rounded-2xl p-6 hover:bg-blue-100 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl"
          >
            <div class="flex items-center space-x-4">
              <div class="w-12 h-12 bg-blue-500 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900">Teléfono</h3>
                <p class="text-blue-600 font-semibold">643 368 225</p>
                <p class="text-sm text-gray-500">Llamada directa</p>
              </div>
            </div>
          </a>
        </div>

        <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6">
          <div class="flex items-center space-x-4 mb-4">
            <div class="w-12 h-12 bg-gray-600 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900">Email</h3>
              <p class="text-gray-600 font-semibold">luismedinagua@gmail.com</p>
              <p class="text-sm text-gray-500">Presupuestos por escrito</p>
            </div>
          </div>
        </div>

        <div class="bg-gradient-to-br from-blue-800 to-cyan-400 rounded-2xl p-8 text-white">
          <h3 class="text-xl font-bold mb-4">Horario de Atención</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center border-b border-blue-300/30 pb-2">
              <span>Lunes - Viernes</span>
              <span class="font-semibold">8:00 - 20:00</span>
            </div>
            <div class="flex justify-between items-center border-b border-blue-300/30 pb-2">
              <span>Sábados</span>
              <span class="font-semibold">9:00 - 15:00</span>
            </div>
            <div class="flex justify-between items-center border-b border-blue-300/30 pb-2">
              <span>Domingos</span>
              <span class="font-semibold">Solo urgencias</span>
            </div>
            <div class="flex justify-between items-center pt-2">
              <span class="text-cyan-200">Emergencias 24h</span>
              <span class="font-bold text-cyan-200">Disponible</span>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-gray-50 rounded-2xl p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Solicitar Presupuesto</h3>
        <form class="space-y-6" id="contact-form">
          <div>
            <label for="nombre" class="block text-sm font-semibold text-gray-700 mb-2">
              Nombre completo *
            </label>
            <input 
              type="text" 
              id="nombre" 
              name="nombre"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
              placeholder="Tu nombre y apellidos"
            >
          </div>

          <div>
            <label for="telefono" class="block text-sm font-semibold text-gray-700 mb-2">
              Teléfono de contacto *
            </label>
            <input 
              type="tel" 
              id="telefono" 
              name="telefono"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
              placeholder="643 368 225"
            >
          </div>

          <div>
            <label for="servicio" class="block text-sm font-semibold text-gray-700 mb-2">
              Tipo de servicio
            </label>
            <select 
              id="servicio" 
              name="servicio"
              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
            >
              <option value="">Selecciona un servicio</option>
              <option value="reparacion-urgencia">Reparación de urgencia</option>
              <option value="instalacion">Instalación de agua</option>
              <option value="calefaccion">Calefacción y termos</option>
              <option value="mantenimiento">Mantenimiento preventivo</option>
              <option value="otro">Otro servicio</option>
            </select>
          </div>

          <div>
            <label for="mensaje" class="block text-sm font-semibold text-gray-700 mb-2">
              Describe tu problema o necesidad *
            </label>
            <textarea 
              id="mensaje" 
              name="mensaje"
              required
              rows="4"
              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors resize-none"
              placeholder="Explícanos qué necesitas para poder darte el mejor servicio..."
            ></textarea>
          </div>

          <button 
            type="submit"
            class="w-full bg-gradient-to-r from-blue-800 to-cyan-400 text-white font-semibold py-4 px-6 rounded-xl hover:from-blue-700 hover:to-cyan-300 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-[1.02] flex items-center justify-center"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
            </svg>
            Enviar Solicitud
          </button>

          <p class="text-sm text-gray-500 text-center">
            * Campos obligatorios. Te responderemos en menos de 2 horas.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

