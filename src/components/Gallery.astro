---
import { Image } from "astro:assets";
import trabajo1 from "../assets/img/img1.jpeg";
import trabajo2 from "../assets/img/img2.jpeg";
import trabajo3 from "../assets/img/img3.jpeg";
import trabajo4 from "../assets/img/img4.jpeg";
import trabajo5 from "../assets/img/img5.jpeg";
import trabajo6 from "../assets/img/img6.jpeg";

const trabajos = [
  { id: 1, label: "Instalación",   titulo: "Cuarto de contadores",     desc: "Instalación completa de cuarto de contadores.", img: trabajo1 },
  { id: 2, label: "Reparación",    titulo: "Fuga en tubería empotrada",         desc: "Detección y reparación de fuga oculta sin afectar al acabado de la pared.", img: trabajo2 },
  { id: 3, label: "Calefacción",   titulo: "Caldera de condensación",           desc: "Instalación de caldera de alto rendimiento con termostato programable.", img: trabajo3 },
  { id: 4, label: "Instalación",   titulo: "Grifería de cocina",                desc: "Sustitución y modernización completa de grifería con modelos de bajo consumo.", img: trabajo4 },
  { id: 5, label: "Reparación",    titulo: "Desatasco urgente",                 desc: "Intervención de urgencia para desatasco en sistema de desagüe en menos de una hora.", img: trabajo5 },
  { id: 6, label: "Calefacción",   titulo: "Termo eléctrico 100L",              desc: "Sustitución de termo antiguo por modelo de bajo consumo con garantía de fabricante.", img: trabajo6 },
];
---

<section id="trabajos" class="py-28 bg-deep overflow-hidden relative">

  <!-- Luz de fondo sutil -->
  <div class="absolute bottom-0 right-0 w-[600px] h-[600px] rounded-full opacity-[0.05] pointer-events-none"
    style="background: radial-gradient(circle, #cf7840 0%, transparent 70%); transform: translate(30%, 30%); filter: blur(80px);"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Cabecera -->
    <div class="text-center mb-12">
      <p class="text-copper font-bold text-xs tracking-widest uppercase mb-4">Galería</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-chalk mb-5 leading-tight">
        Trabajos realizados
      </h2>
      <p class="text-chalk-dim text-lg max-w-2xl mx-auto leading-relaxed">
        Más de 20 años de experiencia avalan la calidad de cada trabajo. Cada proyecto, un resultado garantizado.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {trabajos.map((t) => (
        <div class="group relative rounded-2xl overflow-hidden border border-rim hover:border-border transition-all duration-300">

          <!-- Imagen o placeholder -->
          <div class="aspect-[4/3] relative overflow-hidden">
            {t.img && (
              <Image src={t.img} alt={t.titulo} width={600} height={450} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            )}
            <!-- Badge categoría -->
            <div class="absolute top-3 left-3 z-10">
              <span class="bg-void/60 backdrop-blur-sm text-chalk-dim text-[11px] font-bold tracking-wide uppercase px-3 py-1 rounded-full border border-rim/60">
                {t.label}
              </span>
            </div>

            <!-- Overlay hover -->
            <div class="absolute inset-0 bg-void/80 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col items-center justify-center p-6 text-center z-10">
              <p class="text-chalk font-display font-bold text-lg mb-2 leading-tight">{t.titulo}</p>
              <p class="text-chalk-dim text-sm leading-relaxed mb-5">{t.desc}</p>
              <a
                href="#contacto"
                class="inline-flex items-center gap-2 bg-copper hover:bg-copper-light text-void text-xs font-bold px-5 py-2.5 rounded-lg transition-colors"
              >
                Solicitar similar
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Pie de tarjeta -->
          <div class="px-4 py-3 bg-raised">
            <p class="font-semibold text-chalk-dim text-sm group-hover:text-chalk transition-colors">{t.titulo}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA inferior -->
    <div class="mt-14 text-center">
      <p class="text-chalk-mute text-sm mb-5">¿Necesitas un trabajo similar?</p>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-copper hover:bg-copper-light text-void font-bold px-8 py-4 rounded-xl transition-all duration-200 shadow-xl shadow-copper/20 hover:shadow-copper/35 hover:-translate-y-px"
      >
        Solicitar presupuesto gratuito
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

