---
import Image from "astro/components/Image.astro";
import trabajo1 from "../assets/img/img1.jpeg";
import trabajo2 from "../assets/img/img2.jpeg";
import trabajo3 from "../assets/img/img3.jpeg";


const trabajos = [
  {
    id: 1,
    cat: "instalaciones",
    label: "Instalación",
    titulo: "Renovación de cuarto de baño",
    desc: "Instalación completa de sanitarios, grifería y sistema de desagüe con materiales premium.",
    gradient: "from-sky-500 to-blue-700",
    img: "install",
  },
  {
    id: 2,
    cat: "reparaciones",
    label: "Reparación",
    titulo: "Fuga en tubería empotrada",
    desc: "Detección y reparación de fuga oculta sin afectar al acabado de la pared.",
    gradient: "from-red-500 to-rose-700",
    img: "repair",
  },
  {
    id: 3,
    cat: "calefaccion",
    label: "Calefacción",
    titulo: "Caldera de condensación",
    desc: "Instalación de caldera de alto rendimiento con termostato programable.",
    gradient: "from-orange-500 to-amber-700",
    img: "heat",
  },
  {
    id: 4,
    cat: "instalaciones",
    label: "Instalación",
    titulo: "Grifería de cocina",
    desc: "Sustitución y modernización completa de grifería en cocina con modelos de bajo consumo.",
    gradient: "from-cyan-500 to-teal-700",
    img: "install",
  },
  {
    id: 5,
    cat: "mantenimiento",
    label: "Mantenimiento",
    titulo: "Revisión anual de instalación",
    desc: "Inspección completa y preventiva de toda la red de fontanería del inmueble.",
    gradient: "from-emerald-500 to-green-700",
    img: "maintenance",
  },
  {
    id: 6,
    cat: "reparaciones",
    label: "Reparación",
    titulo: "Desatasco urgente",
    desc: "Intervención de urgencia para desatasco en sistema de desagüe en menos de una hora.",
    gradient: "from-violet-500 to-purple-700",
    img: "repair",
  },
  {
    id: 7,
    cat: "calefaccion",
    label: "Calefacción",
    titulo: "Termo eléctrico 100L",
    desc: "Sustitución de termo antiguo por modelo de bajo consumo con garantía de fabricante.",
    gradient: "from-yellow-500 to-orange-600",
    img: "heat",
  },
  {
    id: 8,
    cat: "instalaciones",
    label: "Instalación",
    titulo: "Circuito hidráulico para piscina",
    desc: "Instalación del sistema completo de filtración y circulación para piscina comunitaria.",
    gradient: "from-blue-500 to-indigo-700",
    img: "install",
  },
  {
    id: 9,
    cat: "mantenimiento",
    label: "Mantenimiento",
    titulo: "Mantenimiento de grupos de presión",
    desc: "Revisión y puesta a punto de grupo de presión en comunidad de vecinos.",
    gradient: "from-slate-500 to-slate-700",
    img: "maintenance",
  },
];
---

<section id="trabajos" class="py-24 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Cabecera -->
    <div class="text-center mb-12">
      <p class="text-sky-500 font-semibold text-sm tracking-widest uppercase mb-3">Galería</p>
      <h2 class="text-4xl font-bold text-slate-900 mb-4">
        Trabajos realizados
      </h2>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto">
        Más de 20 años de experiencia avalan la calidad de nuestros trabajos.
      </p>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto">
        Cada proyecto, un resultado garantizado.
      </p>
    </div>

    <!-- Filtros -->
    <div class="flex flex-wrap justify-center gap-2 mb-10" id="gallery-filters">
      <button data-filter="todos"         class="filter-btn active px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200">Todos</button>
      <button data-filter="instalaciones" class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200">Instalaciones</button>
      <button data-filter="reparaciones"  class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200">Reparaciones</button>
      <button data-filter="calefaccion"   class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200">Calefacción</button>
      <button data-filter="mantenimiento" class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200">Mantenimiento</button>
    </div>

    <!-- Grid de trabajos -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" id="gallery-grid">
      {trabajos.map((t) => (
        <div
          class="gallery-item group relative rounded-2xl overflow-hidden cursor-pointer"
          data-cat={t.cat}
        >
          <!-- Contenedor de imagen con proporción fija -->
          <div class="aspect-[4/3] relative overflow-hidden">

            <!-- Imagen real (ocupa todo el contenedor independientemente de su tamaño original) -->
            {t.img === "install" && (
              <Image src={trabajo1} alt={t.titulo} width={600} height={450} class="absolute inset-0 w-full h-full object-cover" />
            )}
            {t.img === "repair" && (
              <Image src={trabajo2} alt={t.titulo} width={600} height={450} class="absolute inset-0 w-full h-full object-cover" />
            )}
            {t.img === "heat" && (
              <Image src={trabajo3} alt={t.titulo} width={600} height={450} class="absolute inset-0 w-full h-full object-cover" />
            )}
            {t.img === "maintenance" && (
              <div class={`absolute inset-0 bg-gradient-to-br ${t.gradient} flex items-center justify-center`}>
                <svg class="w-20 h-20 text-white opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
            )}

            <!-- Badge de categoría -->
            <div class="absolute top-3 left-3 z-10">
              <span class="bg-black/40 backdrop-blur-sm text-white text-xs font-semibold px-3 py-1 rounded-full">
                {t.label}
              </span>
            </div>

            <!-- Overlay hover -->
            <div class="absolute inset-0 bg-slate-900/75 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center z-10">
              <p class="text-white font-bold text-lg mb-2">{t.titulo}</p>
              <p class="text-slate-300 text-sm leading-relaxed mb-5">{t.desc}</p>
              <a
                href="#contacto"
                class="inline-flex items-center gap-2 bg-sky-500 hover:bg-sky-400 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors"
              >
                Solicitar similar
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Info inferior -->
          <div class="px-4 py-3 bg-white border border-slate-100 border-t-0 rounded-b-2xl">
            <p class="font-semibold text-slate-900 text-sm">{t.titulo}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA inferior -->
    <div class="mt-14 text-center">
      <p class="text-slate-500 text-sm mb-4">¿Necesitas un trabajo similar?</p>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-sky-500 hover:bg-sky-400 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors shadow-lg shadow-sky-500/20"
      >
        Solicitar presupuesto gratuito
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .filter-btn {
    background: transparent;
    color: #64748b;
    border: 1px solid #e2e8f0;
  }
  .filter-btn:hover {
    background: #f8fafc;
    color: #0f172a;
    border-color: #cbd5e1;
  }
  .filter-btn.active {
    background: #0ea5e9;
    color: #ffffff;
    border-color: #0ea5e9;
    box-shadow: 0 4px 14px rgba(14, 165, 233, 0.25);
  }
  .gallery-item {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .gallery-item.hidden-item {
    display: none;
  }
</style>

<script>
  const btns   = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items  = document.querySelectorAll<HTMLElement>('.gallery-item');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter as string;

      // Actualizar botón activo
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Filtrar items
      items.forEach((item) => {
        const cat = item.dataset.cat as string;
        if (filter === 'todos' || cat === filter) {
          item.classList.remove('hidden-item');
        } else {
          item.classList.add('hidden-item');
        }
      });
    });
  });
</script>
