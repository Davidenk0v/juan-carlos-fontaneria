---
---

<section id="inicio" class="pt-20 bg-gradient-to-br from-blue-800 via-blue-700 to-cyan-400 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <div class="space-y-4">
          <h1 class="text-4xl md:text-6xl font-bold leading-tight">
            L&M Fontanero
            <span class="block text-cyan-300">Autorizado</span>
          </h1>
          <p class="text-xl md:text-2xl text-blue-100 leading-relaxed">
            Tu fontanero de confianza para reparaciones, instalaciones y mantenimiento
          </p>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="#contacto" 
            class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold bg-cyan-400 text-blue-800 rounded-2xl hover:bg-cyan-300 transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:scale-105"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
            </svg>
            Solicitar Presupuesto
          </a>
          
          <a 
            href="https://wa.me/34643368225" 
            target="_blank"
            class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold bg-green-500 text-white rounded-2xl hover:bg-green-400 transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:scale-105"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
            </svg>
            WhatsApp
          </a>
        </div>

        <div class="flex items-center space-x-6 text-blue-100">
          <div class="flex items-center space-x-2">
            <svg class="w-5 h-5 text-cyan-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span>Servicio 24/7</span>
          </div>
          <div class="flex items-center space-x-2">
            <svg class="w-5 h-5 text-cyan-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>Fontanero Autorizado</span>
          </div>
        </div>
      </div>
      
      <div class="relative">
        <div class="relative z-10 bg-white/10 backdrop-blur-sm rounded-3xl p-8 border border-white/20">
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center">
              <div class="w-16 h-16 bg-cyan-400 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-blue-800" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
              </div>
              <h3 class="font-semibold">Reparaciones</h3>
              <p class="text-sm text-blue-100">Urgentes</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 bg-cyan-400 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-blue-800" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14h-4v-4h4v4zm0-6h-4V7h4v4z"/>
                </svg>
              </div>
              <h3 class="font-semibold">Instalaciones</h3>
              <p class="text-sm text-blue-100">Completas</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 bg-cyan-400 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-blue-800" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12.5 2C13.3 2 14 2.7 14 3.5v2c0 .8-.7 1.5-1.5 1.5S11 6.3 11 5.5v-2c0-.8.7-1.5 1.5-1.5zM21 11h-2c-.8 0-1.5.7-1.5 1.5s.7 1.5 1.5 1.5h2c.8 0 1.5-.7 1.5-1.5S21.8 11 21 11zM6.5 11H5c-.8 0-1.5.7-1.5 1.5S4.2 14 5 14h1.5c.8 0 1.5-.7 1.5-1.5S7.3 11 6.5 11z"/>
                </svg>
              </div>
              <h3 class="font-semibold">Calefacción</h3>
              <p class="text-sm text-blue-100">Y Termos</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 bg-cyan-400 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-blue-800" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/>
                </svg>
              </div>
              <h3 class="font-semibold">Mantenimiento</h3>
              <p class="text-sm text-blue-100">Preventivo</p>
            </div>
          </div>
        </div>
        
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-cyan-300/20 rounded-full"></div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-blue-600/20 rounded-full"></div>
      </div>
    </div>
  </div>
  
  <div class="w-full h-1 bg-gradient-to-r from-cyan-400 to-blue-600"></div>
</section>
