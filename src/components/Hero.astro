---
---

<section id="inicio" class="relative pt-24 min-h-[100svh] bg-slate-900 flex items-center overflow-hidden">

  <!-- Patrón de puntos de fondo -->
  <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(148,163,184,0.07) 1px, transparent 1px); background-size: 28px 28px;"></div>

  <!-- Esferas decorativas de fondo -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-sky-500/15 rounded-full blur-3xl translate-x-1/3 -translate-y-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-blue-700/10 rounded-full blur-3xl -translate-x-1/4 translate-y-1/4"></div>
    <div class="absolute top-1/2 left-1/2 w-[400px] h-[400px] bg-cyan-500/5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24 w-full">

    <!-- Badge de urgencias -->
    <div class="inline-flex items-center gap-2 bg-red-500/10 border border-red-500/20 text-red-400 rounded-full px-4 py-1.5 text-sm font-medium mb-10">
      <span class="w-2 h-2 bg-red-400 rounded-full animate-pulse"></span>
      Urgencias 24 horas
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Columna izquierda: texto y CTAs -->
      <div class="space-y-6">
        <h1 class="text-5xl md:text-6xl lg:text-[4.5rem] font-extrabold leading-[1.05] tracking-tight">
          <span class="text-white">Fontanero</span><br>
          <span class="text-sky-400">autorizado</span><br>
          <span class="text-white">de confianza</span>
        </h1>

        <p class="text-lg text-slate-400 leading-relaxed max-w-md">
          Fontanero autorizado con más de 20 años de experiencia en reparaciones, instalaciones y mantenimiento de fontanería en Tenerife.
        </p>
        <p class="text-lg text-slate-400 leading-relaxed max-w-md">
          Licencia N° 05-B-D90.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="#contacto"
            class="inline-flex items-center justify-center px-7 py-3.5 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-xl transition-colors text-base shadow-lg shadow-sky-500/20"
          >
            Solicitar presupuesto gratis
          </a>
          <a
            href="https://wa.me/34643368225"
            target="_blank"
            class="inline-flex items-center justify-center gap-2.5 px-7 py-3.5 border border-white/15 hover:bg-white/5 text-white font-semibold rounded-xl transition-colors text-base"
          >
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
            </svg>
            WhatsApp
          </a>
        </div>

        <!-- Stats de confianza -->
        <div class="grid grid-cols-3 gap-6 pt-8 border-t border-white/10">
          <div>
            <p class="text-3xl font-bold text-sky-400">24h</p>
            <p class="text-sm text-slate-400 mt-1">Urgencias</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-sky-400">100%</p>
            <p class="text-sm text-slate-400 mt-1">Trabajos garantizados</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-sky-400">+20</p>
            <p class="text-sm text-slate-400 mt-1">Años de experiencia</p>
          </div>
        </div>
      </div>

      <!-- Columna derecha: tarjetas de servicios -->
      <div class="grid grid-cols-2 gap-3">

        <!-- Reparaciones -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition-colors">
          <div class="w-10 h-10 bg-red-500/15 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm mb-1">Reparaciones</h3>
          <p class="text-xs text-slate-400 leading-relaxed">Fugas, atascos y averías urgentes</p>
        </div>

        <!-- Instalaciones -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition-colors">
          <div class="w-10 h-10 bg-sky-500/15 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm mb-1">Instalaciones</h3>
          <p class="text-xs text-slate-400 leading-relaxed">Tuberías, grifería y sanitarios</p>
        </div>

        <!-- Calefacción -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition-colors">
          <div class="w-10 h-10 bg-orange-500/15 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm mb-1">Calefacción</h3>
          <p class="text-xs text-slate-400 leading-relaxed">Calderas, termos y radiadores</p>
        </div>

        <!-- Mantenimiento -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition-colors">
          <div class="w-10 h-10 bg-emerald-500/15 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm mb-1">Mantenimiento</h3>
          <p class="text-xs text-slate-400 leading-relaxed">Revisiones preventivas periódicas</p>
        </div>

      </div>
    </div>
  </div>

  <!-- Separador wave inferior -->
  <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12 md:h-16">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="white"/>
    </svg>
  </div>
</section>
