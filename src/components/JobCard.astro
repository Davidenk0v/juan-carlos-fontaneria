---
const iconBgMap = {
  red:     "bg-red-500/10     border-red-500/20",
  blue:    "bg-sky-500/10     border-sky-500/20",
  orange:  "bg-orange-500/10  border-orange-500/20",
  emerald: "bg-emerald-500/10 border-emerald-500/20",
} as const;

type Background = keyof typeof iconBgMap;

interface Props {
  title: string;
  description: string;
  background: Background;
}

const { title, description, background } = Astro.props;
const iconBg = iconBgMap[background];
---

<div class="bg-raised border border-rim rounded-2xl p-5 hover:bg-high hover:border-border transition-all duration-300 group">
  <div class={`w-10 h-10 ${iconBg} border rounded-xl flex items-center justify-center mb-4`}>
    <slot />
  </div>
  <h3 class="font-semibold text-chalk text-sm mb-1.5">{title}</h3>
  <p class="text-xs text-chalk-mute leading-relaxed">{description}</p>
</div>
