---
const bgMap = {
  red:    "bg-red-500/15",
  blue:   "bg-blue-500/15",
  emerald:  "bg-emerald-500/15",
  orange: "bg-orange-500/15",
} as const;

type Background = keyof typeof bgMap;

interface Props {
  title: string;
  description: string;
  background: Background;
}

const { title, description, background } = Astro.props;
const bgClass = bgMap[background];
---

<div class="bg-white/5 border border-white/10 rounded-2xl p-5 hover:bg-white/10 transition-colors">
  <div class={`w-10 h-10 ${bgClass} rounded-xl flex items-center justify-center mb-4`}>
    <slot />
  </div>
  <h3 class="font-semibold text-white text-sm mb-1">{title}</h3>
  <p class="text-xs text-slate-400 leading-relaxed">{description}</p>
</div>